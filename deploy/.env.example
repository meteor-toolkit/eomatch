# Copy this file to .env and fill in the values before running docker compose.
# Never commit .env to version control.

# PostgreSQL credentials
POSTGRES_DB=eomatch
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# API key required for write operations (POST / PUT / DELETE).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_API_KEY=change-me-api-key

# Port on the host that the STAC API + Browser is exposed on (default: 8000).
LISTEN_PORT=8000

# Path to the catalogue root directory, served statically at /catalogue/ so the
# STAC Browser can load thumbnails and other assets.
# Pass to eomatch-ingest via --assets-base-url http://your-server:8000/catalogue
CATALOGUE_PATH=/data/eomatch/catalogue

# Port on the host that PostgreSQL is exposed on (default: 5432).
# Restrict this to the internal network at the firewall — do not expose publicly.
POSTGRES_LISTEN_PORT=5432
